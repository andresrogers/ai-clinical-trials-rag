# OpenAI API
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_ORG_ID=org-your-org-id  # Optional

# OpenRouter API
OPENROUTER_API_KEY="or-..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Vector Database (choose one or both)
CHROMA_PERSIST_DIR=./data/processed/vectorstore/chroma
PINECONE_API_KEY=your-pinecone-key  # Optional
PINECONE_ENVIRONMENT=us-west1-gcp  # Optional
PINECONE_INDEX_NAME=ai-clinical-trials-rag  # Optional

# Google Drive (for PDF loading)
GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here
GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials/google_drive_credentials.json

# MLflow (optional)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=ai-clinical-trials-rag

# Application settings
LOG_LEVEL=INFO
CACHE_DIR=./data/cache
MAX_TOKENS=4000
TEMPERATURE=0.0
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5